{
  "name": "branch-beacon-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "storybook": "pnpm --filter @branch-beacon/storybook storybook",
    "storybook:build": "pnpm --filter @branch-beacon/storybook build-storybook",
    "verify-use-client": "node scripts/verify-use-client.mjs"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.6.3"
  }
}
