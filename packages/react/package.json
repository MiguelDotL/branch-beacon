{
  "name": "branch-beacon",
  "version": "0.1.0",
  "description": "Drop-in git branch indicator for dev tools and dashboards. Adapts to your host project's design tokens; hides in production by default.",
  "keywords": [
    "git",
    "branch",
    "indicator",
    "dev-tools",
    "react",
    "dashboard"
  ],
  "author": "Miguel Lozano",
  "license": "MIT",
  "homepage": "https://github.com/MiguelDotL/branch-beacon",
  "repository": {
    "type": "git",
    "url": "https://github.com/MiguelDotL/branch-beacon.git",
    "directory": "packages/react"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": {
          "import": "./dist/index.d.ts",
          "require": "./dist/index.d.cts"
        },
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@branch-beacon/core": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "msw": "^2.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
